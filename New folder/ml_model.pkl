import pickle
import numpy as np
from sklearn.linear_model import LinearRegression

# Training Data: [Complexity 1-5] -> [Estimated Hours]
X = np.array([[1], [2], [3], [4], [5]])
y = np.array([2, 5, 12, 24, 40]) 

# Train the model
model = LinearRegression()
model.fit(X, y)

# Save the model as ml_model.pkl
with open('ml_model.pkl', 'wb') as f:
    pickle.dump(model, f)

print("ml_model.pkl has been created successfully!")